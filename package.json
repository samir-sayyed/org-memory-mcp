{
  "name": "org-memory-mcp",
  "version": "1.0.0",
  "description": "Org-wide persisted memory layer for AI coding agents via AWS Bedrock AgentCore",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "org-memory-mcp": "./build/index.js"
  },
  "files": [
    "build/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r src/visualizer build/visualizer && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "dev": "nodemon --exec ts-node --esm src/index.ts",
    "start": "node build/index.js",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "visualize": "node --loader ts-node/esm src/visualize.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "memory", "aws", "bedrock", "agentcore", "coding-agent"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^1.0.0",
    "@aws-sdk/client-bedrock-agentcore": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}