# AWS Credentials
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Optional: defaults to us-west-2 when omitted
AWS_REGION=us-west-2

# AWS Bedrock AgentCore Memory Resource ARN
MEMORY_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:memory/your-memory-id

# Organization & User Identity
# Must not contain spaces or forward slashes
ORG_ID=your-org-id
# Must not contain spaces or forward slashes
ACTOR_ID=developer@company.com

# Required: Organization access token for auth tracking
AUTH_TOKEN=your-org-access-token

# Optional: Session ID for short-term memory grouping
# Auto-generated as "coding-YYYYMMDD-HHMMSS-XXXX" when omitted
# SESSION_ID=my-coding-session-1

# Optional: AWS Session Token (if using temporary credentials)
# AWS_SESSION_TOKEN=your-session-token

# Optional: Actor role for access control
# developer = user + project writes only
# admin = can also write org-wide memories
ACTOR_ROLE=developer
